<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- القاعدة الأمنية الخاصة بإظهار وإخفاء أنواع الموافقات حسب المجموعات -->
        <record id="approval_category_visibility_rule" model="ir.rule">
            <field name="name">Approval Category Visibility based on Groups</field>
            <field name="model_id" ref="approvals.model_approval_category"/>
            <field name="domain_force">
                ['|', ('allowed_group_ids', '=', False), ('allowed_group_ids', 'in', user.groups_id.ids)]
            </field>
            <!-- نطبق هذه القاعدة على جميع الموظفين -->
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
